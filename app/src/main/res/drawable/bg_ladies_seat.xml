<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base pink background -->
    <item
        >
        <shape android:shape="rectangle">
            <solid android:color="#FFCCE5"/>
            <corners android:topLeftRadius="@dimen/dimen_1dp"
                android:topRightRadius="@dimen/dimen_1dp"
                android:bottomLeftRadius="@dimen/dimen_1dp"
                android:bottomRightRadius="@dimen/dimen_1dp"/>
        </shape>
    </item>

    <!-- Female icon overlay (centered) -->
    <item
        android:drawable="@drawable/ic_ladies"
        android:gravity="center" />

</layer-list>
