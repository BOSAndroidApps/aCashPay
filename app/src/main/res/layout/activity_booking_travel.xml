<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Navigation Drawer -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <RelativeLayout
            android:id="@+id/inactiveservicelayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:elevation="@dimen/dimen_1dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:alpha=".5"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardUseCompatPadding="true"
                android:layout_marginHorizontal="@dimen/dimen_10dp"
                android:layout_marginTop="@dimen/dimen_140dp"
                app:cardCornerRadius="@dimen/dimen_8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:elevation="@dimen/dimen_1dp"
                    android:paddingBottom="@dimen/dimen_10dp"
                    android:paddingLeft="@dimen/dimen_8dp"
                    android:paddingRight="8dp"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/lockicon"
                        android:layout_width="@dimen/dimen_100dp"
                        android:layout_height="@dimen/dimen_100dp"
                        android:src="@drawable/padlock"
                        android:layout_gravity="center"
                        android:padding="@dimen/dimen_10dp"
                        android:layout_centerInParent="true"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/lockicon"
                        android:gravity="center"
                        android:text="Service Inactive"
                        android:textColor="@color/black"
                        android:padding="@dimen/dimen_6dp"
                        android:textSize="@dimen/dimen_16sp"
                        android:fontFamily="@font/roboto_bold"/>


                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/lockicon"
                        android:gravity="center"
                        android:text="Bus service currently unavailable for your account,Please contact with your Admin ."
                        android:textColor="@color/edittext_color"
                        android:padding="@dimen/dimen_6dp"
                        android:textSize="@dimen/dimen_12sp"
                        android:fontFamily="@font/roboto_regular"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/relativeLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_20dp">


                        <LinearLayout
                            android:id="@+id/fromcityLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/fromtoback"
                            android:orientation="vertical"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintRight_toRightOf="parent"
                            android:layout_marginTop="@dimen/dimen_6dp"
                            android:layout_marginHorizontal="@dimen/dimen_6dp"
                            android:padding="@dimen/dimen_10dp">

                            <LinearLayout
                                android:id="@+id/fromlayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <ImageView
                                    android:id="@+id/imageview"
                                    android:layout_weight=".2"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/dimen_30dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/fromiconbus" />

                                <LinearLayout
                                    android:layout_weight="1"
                                    android:layout_width="0dp"
                                    android:orientation="vertical"
                                    android:layout_height="wrap_content">

                                    <TextView
                                        android:text="@string/fromcity"
                                        android:layout_width="match_parent"
                                        android:fontFamily="@font/roboto_bold"
                                        android:layout_height="wrap_content"/>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:id="@+id/fromcityname"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textColor="@color/black"
                                            android:text="Delhi"
                                            android:textAllCaps="true"
                                            android:fontFamily="@font/roboto_bold"
                                            android:textColorHint="@color/black"
                                            android:textSize="@dimen/dimen_14sp"/>

                                    </LinearLayout>

                                </LinearLayout>

                            </LinearLayout>

                            <com.bos.payment.appName.utils.searchableSp.SearchableSpinner
                                android:id="@+id/fromDestinationSp"
                                android:layout_width="match_parent"
                                android:layout_height="?attr/dropdownListPreferredItemHeight"
                                android:gravity="center"
                                android:background="@null"
                                android:visibility="gone"/>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/tocityLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/fromtoback"
                            android:orientation="vertical"
                            app:layout_constraintTop_toBottomOf="@+id/fromcityLayout"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintRight_toRightOf="parent"
                            android:layout_marginTop="@dimen/dimen_6dp"
                            android:layout_marginHorizontal="@dimen/dimen_6dp"
                            android:padding="@dimen/dimen_10dp">

                            <LinearLayout
                                android:id="@+id/tolayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <ImageView
                                    android:layout_weight=".2"
                                    android:layout_width="0dp"
                                    android:layout_height="@dimen/dimen_30dp"
                                    android:src="@drawable/ic_location_on_light_blue_24dp"
                                    app:tint="@color/black"
                                    android:layout_gravity="center" />

                                <LinearLayout
                                    android:layout_weight="1"
                                    android:layout_width="0dp"
                                    android:orientation="vertical"
                                    android:layout_height="wrap_content">

                                    <TextView
                                        android:text="@string/tocity"
                                        android:layout_width="match_parent"
                                        android:fontFamily="@font/roboto_bold"
                                        android:layout_height="wrap_content"/>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:id="@+id/tocityname"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:textColor="@color/black"
                                            android:text="Mumbai"
                                            android:textAllCaps="true"
                                            android:fontFamily="@font/roboto_bold"
                                            android:textColorHint="@color/black"
                                            android:textSize="@dimen/dimen_14sp"/>


                                    </LinearLayout>


                                </LinearLayout>

                            </LinearLayout>

                            <com.bos.payment.appName.utils.searchableSp.SearchableSpinner
                                android:id="@+id/toDestinationSp"
                                android:layout_width="match_parent"
                                android:layout_height="?attr/dropdownListPreferredItemHeight"
                                android:gravity="center"
                                android:background="@null"
                                android:visibility="gone"/>

                        </LinearLayout>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/reversetrip"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginRight="@dimen/dimen_6dp"
                            app:cardCornerRadius="@dimen/dimen_6dp"
                            app:cardElevation="@dimen/dimen_4dp"
                            app:layout_constraintRight_toRightOf="@+id/fromcityLayout"
                            app:layout_constraintTop_toTopOf="@+id/fromcityLayout"
                            app:layout_constraintBottom_toBottomOf="@+id/tocityLayout">

                            <ImageView
                                android:layout_width="@dimen/dimen_20dp"
                                android:layout_height="@dimen/dimen_20dp"
                                android:src="@drawable/swapicon"
                                android:layout_gravity="center"
                                app:tint="@color/blue"/>

                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:id="@+id/dateselecetionlayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/fromtoback"
                            android:layout_marginTop="@dimen/dimen_10dp"
                            android:layout_marginHorizontal="@dimen/dimen_6dp"
                            app:layout_constraintTop_toBottomOf="@+id/tocityLayout">

                            <LinearLayout
                                android:layout_weight=".9"
                                android:id="@+id/departureDatelayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toBottomOf="@+id/fromcityLayout"
                                android:layout_gravity="center"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintRight_toRightOf="parent"
                                android:layout_marginHorizontal="@dimen/dimen_6dp"
                                android:padding="@dimen/dimen_6dp">

                                <ImageView
                                    android:layout_weight=".2"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:src="@drawable/calendar_icon"
                                    android:layout_gravity="center"
                                    app:tint="@color/text_hint_color"/>

                                <LinearLayout
                                    android:layout_weight="1"
                                    android:layout_width="0dp"
                                    android:orientation="vertical"
                                    android:layout_height="wrap_content">

                                    <TextView
                                        android:text="@string/departuredate"
                                        android:layout_width="match_parent"
                                        android:fontFamily="@font/roboto_bold"
                                        android:textSize="@dimen/dimen_12sp"
                                        android:layout_height="wrap_content"/>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:id="@+id/datemonthdeparture"
                                            android:layout_width="wrap_content"
                                            android:layout_height="match_parent"
                                            android:hint="28 Jun"
                                            android:textColor="@color/black"
                                            android:textColorHint="@color/black"
                                            android:textSize="@dimen/dimen_12sp"
                                            android:fontFamily="@font/roboto_bold"/>

                                        <TextView
                                            android:id="@+id/dayyear"
                                            android:hint="Sat,2025"
                                            android:fontFamily="@font/roboto_regular"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:textSize="@dimen/dimen_12sp"
                                            android:layout_marginLeft="@dimen/dimen_4dp"/>

                                    </LinearLayout>

                                </LinearLayout>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_weight="1"
                                android:id="@+id/addreturndatelayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="@dimen/dimen_8dp"
                                app:layout_constraintTop_toBottomOf="@+id/fromcityLayout"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintRight_toRightOf="parent"
                                android:layout_gravity="center">

                                <LinearLayout
                                    android:id="@+id/todaylayout"
                                    android:layout_weight=".5"
                                    android:layout_width="0dp"
                                    android:orientation="vertical"
                                    android:background="@drawable/selectedbutton"
                                    android:layout_marginLeft="@dimen/dimen_6dp"
                                    android:layout_gravity="center"
                                    android:padding="@dimen/dimen_4dp"
                                    android:gravity="center"
                                    app:layout_constraintLeft_toLeftOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:layout_constraintRight_toRightOf="parent"
                                    android:layout_height="wrap_content">

                                    <TextView
                                        android:id="@+id/todaytxt"
                                        android:text="TODAY"
                                        android:layout_width="wrap_content"
                                        android:fontFamily="@font/roboto_bold"
                                        android:textSize="@dimen/dimen_12sp"
                                        android:textColor="@color/blue"
                                        android:layout_height="wrap_content"/>

                                </LinearLayout>

                                <LinearLayout
                                    android:id="@+id/tomorrowlayout"
                                    android:layout_weight=".5"
                                    android:layout_width="0dp"
                                    android:orientation="vertical"
                                    android:background="@drawable/fromtoback"
                                    android:layout_marginLeft="@dimen/dimen_6dp"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:padding="@dimen/dimen_4dp"
                                    app:layout_constraintLeft_toLeftOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"
                                    app:layout_constraintRight_toRightOf="parent"
                                    android:layout_height="wrap_content">

                                    <TextView
                                        android:id="@+id/tomorrowtxt"
                                        android:text="TOMMOROW"
                                        android:layout_width="wrap_content"
                                        android:fontFamily="@font/roboto_bold"
                                        android:textSize="@dimen/dimen_12sp"
                                        android:textColor="@color/mode_color"
                                        android:layout_height="wrap_content"/>

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/searchbuseslayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dimen_20dp"
                            android:layout_marginHorizontal="@dimen/dimen_6dp"
                            android:background="@drawable/searchbutton"
                            app:layout_constraintTop_toBottomOf="@+id/dateselecetionlayout">

                            <TextView
                                android:text="Buses Search"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:textColor="@color/white"
                                android:textSize="@dimen/dimen_14sp"
                                android:fontFamily="@font/roboto_bold"
                                android:padding="@dimen/dimen_10dp"/>


                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>

            </ScrollView>

        </RelativeLayout>


    <LinearLayout
        android:id="@+id/bottomview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <androidx.cardview.widget.CardView
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen_10dp"
        android:layout_gravity="bottom|center_horizontal"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="@dimen/dimen_30dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigationView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            app:itemIconTint="@color/colorPrimaryDark"
            app:menu="@menu/booking_menu" />

    </androidx.cardview.widget.CardView>

    </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.drawerlayout.widget.DrawerLayout>