<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="72dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_margin="@dimen/dimen_4dp">

    <androidx.cardview.widget.CardView
        android:layout_width="68dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/dimen_10dp"
        android:layout_margin="@dimen/dimen_4dp"
        android:paddingBottom="@dimen/dimen_10dp"
        android:layout_gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginTop="@dimen/dimen_6dp"
            android:paddingBottom="@dimen/dimen_10dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/servicecard"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="@dimen/dimen_10dp"
                android:layout_margin="3dp"
                app:cardBackgroundColor="@color/colorPrimary"
                android:layout_centerInParent="true"
                android:layout_gravity="center">

                <ImageView
                    android:id="@+id/servicesImage"
                    android:layout_width="@dimen/dimen_40dp"
                    android:layout_height="@dimen/dimen_40dp"
                    android:src="@drawable/eminew"
                    android:padding="3dp"
                    app:tint="@color/white"
                    android:layout_gravity="center"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:contentDescription="@string/app_name" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/servicesName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bank Transfer"
                android:textSize="@dimen/dimen_10sp"
                android:fontFamily="@font/roboto_medium"
                android:textColor="@color/black"
                android:textAlignment="center"
                android:layout_marginTop="@dimen/dimen_6dp"
                android:paddingBottom="7dp"
                app:layout_constraintStart_toEndOf="@id/servicecard"
                app:layout_constraintTop_toTopOf="@id/servicecard"
                app:layout_constraintBottom_toBottomOf="@id/servicecard"
                app:layout_constraintEnd_toEndOf="parent" />

        </LinearLayout>


    </androidx.cardview.widget.CardView>

</LinearLayout>