<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.view.promocode.RetailerPromocodeDetailsPage">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RelativeLayout
                android:id="@+id/header"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_56dp"
                android:background="@color/blue"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="@dimen/dimen_10dp"
                    android:src="@drawable/ic_back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:gravity="center"
                    android:padding="@dimen/dimen_10dp"
                    android:text="Wallet Promo Details"
                    android:textColor="@color/white"
                    android:textSize="17sp" />


            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dimen_6dp"
                android:layout_marginTop="@dimen/dimen_10dp"
                app:cardCornerRadius="@dimen/dimen_8dp"
                app:cardUseCompatPadding="true"
                app:layout_constraintTop_toBottomOf="@+id/header">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dimen_140dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/cloudimage" />

                    <ImageView
                        android:layout_width="@dimen/dimen_200dp"
                        android:layout_height="@dimen/dimen_120dp"
                        android:layout_centerInParent="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/walletpromoicon" />

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/promonamecard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dimen_4dp"
                android:layout_marginTop="-40dp"
                app:cardCornerRadius="@dimen/dimen_14dp"
                app:cardUseCompatPadding="true"
                app:layout_constraintTop_toBottomOf="@+id/banner">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/dimen_6dp">

                    <TextView
                        android:id="@+id/promocode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentLeft="true"
                        android:layout_marginLeft="@dimen/dimen_4dp"
                        android:layout_marginTop="@dimen/dimen_4dp"
                        android:fontFamily="@font/roboto_bold"
                        android:text="WALLETTOP"
                        android:textColor="@color/black"
                        android:textSize="@dimen/dimen_16sp"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/statuslayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@+id/promocode">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/promotionTypecard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_gravity="end"
                            android:layout_marginLeft="-30dp"
                            android:layout_marginTop="@dimen/dimen_4dp"
                            android:layout_marginRight="@dimen/dimen_6dp"
                            app:cardBackgroundColor="@color/light_orange_promo"
                            app:cardCornerRadius="@dimen/dimen_8dp"
                            app:cardUseCompatPadding="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintLeft_toRightOf="@+id/statuscard"
                            app:layout_constraintTop_toTopOf="parent">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginLeft="10dp"
                                android:gravity="center"
                                android:paddingHorizontal="@dimen/dimen_10dp">

                                <TextView
                                    android:id="@+id/promotionType_applicationMode"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/roboto_regular"
                                    android:gravity="center"
                                    android:paddingHorizontal="@dimen/dimen_10dp"
                                    android:paddingVertical="@dimen/dimen_4dp"
                                    android:text="WALLET Cashback"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/dimen_12sp"
                                    android:textStyle="bold" />


                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/statuscard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:layout_gravity="end"
                            android:layout_marginTop="@dimen/dimen_4dp"
                            android:layout_marginRight="@dimen/dimen_6dp"
                            app:cardBackgroundColor="@color/green"
                            app:cardCornerRadius="@dimen/dimen_8dp"
                            app:cardUseCompatPadding="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/roboto_regular"
                                    android:gravity="center"
                                    android:paddingHorizontal="@dimen/dimen_16dp"
                                    android:paddingVertical="@dimen/dimen_4dp"
                                    android:text="Active"
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/dimen_12sp"
                                    android:textStyle="bold" />

                            </LinearLayout>


                        </androidx.cardview.widget.CardView>


                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/promoname"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/promocode"
                        android:layout_marginLeft="@dimen/dimen_6dp"
                        android:layout_marginTop="@dimen/dimen_6dp"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Wallet Top - Up Offer"
                        android:textColor="@color/blue"
                        android:textSize="@dimen/dimen_18sp"
                        app:layout_constraintTop_toBottomOf="@+id/statuslayout" />

                    <LinearLayout
                        android:id="@+id/offerlayout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/promoname">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/dimen_6dp"
                            android:fontFamily="@font/roboto_bold"
                            android:paddingVertical="@dimen/dimen_4dp"
                            android:text="Get"
                            android:textColor="@color/black"
                            android:textSize="@dimen/dimen_18sp" />

                        <TextView
                            android:id="@+id/offeramount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/dimen_4dp"
                            android:fontFamily="@font/roboto_bold"
                            android:paddingVertical="@dimen/dimen_4dp"
                            android:text=" ₹ 500 "
                            android:textColor="@color/dark_green"
                            android:textSize="@dimen/dimen_20sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/maxdiscount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dimen_6dp"
                        android:fontFamily="@font/roboto_bold"
                        android:paddingVertical="@dimen/dimen_4dp"
                        android:text="Cashback Up to ₹500 "
                        android:textColor="@color/blue"
                        android:textSize="@dimen/dimen_16sp"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/offerlayout" />

                    <TextView
                        android:id="@+id/offermessage1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/offermsglayouttop"
                        android:fontFamily="@font/roboto_medium"
                        android:gravity="start"
                        android:layout_marginLeft="@dimen/dimen_4dp"
                        android:padding="@dimen/dimen_4dp"
                        android:text="@string/use_promoa"
                        android:textColor="@color/edittext_color"
                        android:textSize="@dimen/dimen_16sp"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/maxdiscount" />

                    <TextView
                        android:id="@+id/offermessage2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/offermsglayoutbottom"
                        android:fontFamily="@font/roboto_medium"
                        android:gravity="start"
                        android:padding="@dimen/dimen_4dp"
                        android:text="@string/use_promob"
                        android:textColor="@color/edittext_color"
                        android:textSize="@dimen/dimen_16sp"
                        android:layout_marginLeft="@dimen/dimen_4dp"
                        android:layout_marginBottom="@dimen/dimen_6dp"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/offermessage1" />

                    <ImageView
                        android:id="@+id/walleticon"
                        android:layout_width="165dp"
                        android:layout_height="@dimen/dimen_120dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/walletpromoicon"
                        android:padding="@dimen/dimen_6dp"
                        app:layout_constraintBottom_toTopOf="@+id/offermessage2"
                        app:layout_constraintLeft_toRightOf="@+id/maxdiscount"
                        app:layout_constraintRight_toRightOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/validitycard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/dimen_8dp"
                app:cardUseCompatPadding="true"
                android:layout_marginHorizontal="@dimen/dimen_4dp"
                app:layout_constraintTop_toBottomOf="@+id/promonamecard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dimen_10dp"
                    android:paddingBottom="@dimen/dimen_12dp">

                    <LinearLayout
                        android:id="@+id/validitytitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_10dp"
                        android:paddingVertical="@dimen/dimen_6dp"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_bold"
                            android:padding="@dimen/dimen_4dp"
                            android:text="Validity Period"
                            android:textColor="@color/black"
                            android:textSize="@dimen/dimen_14sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/fromdatelayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@+id/validitytitle">

                        <ImageView
                            android:layout_width="@dimen/dimen_20dp"
                            android:layout_height="@dimen/dimen_20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/clockicon"
                            app:tint="@color/black"
                            android:padding="@dimen/dimen_2dp"/>

                        <TextView
                            android:id="@+id/fromdate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/dimen_6dp"
                            android:fontFamily="@font/roboto_medium"
                            android:text="21 Dec 2025, 10:10 am"
                            android:textColor="@color/black"
                            android:textSize="@dimen/dimen_14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:text="-"
                            android:gravity="center"
                            android:layout_marginLeft="@dimen/dimen_4dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/dimen_14sp" />

                        <TextView
                            android:id="@+id/todate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/dimen_4dp"
                            android:fontFamily="@font/roboto_medium"
                            android:text="30 Dec 2025, 03:00 am"
                            android:textColor="@color/black"
                            android:textSize="@dimen/dimen_14sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/limitedusagelayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_4dp"
                        app:layout_constraintTop_toBottomOf="@+id/fromdatelayout">

                        <ImageView
                            android:layout_width="@dimen/dimen_20dp"
                            android:layout_height="@dimen/dimen_20dp"
                            android:layout_gravity="center"
                            android:padding="@dimen/dimen_2dp"
                            android:src="@drawable/usericon"
                            app:tint="@color/green" />

                        <TextView
                            android:id="@+id/limitedusage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/roboto_medium"
                            android:text="You can use this promo code up to "
                            android:layout_marginLeft="@dimen/dimen_6dp"
                            android:textColor="@color/edittext_color"
                            android:textSize="@dimen/dimen_14sp" />

                        <TextView
                            android:id="@+id/maxlimited"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/roboto_bold"
                            android:textColor="@color/edittext_color"
                            android:textSize="@dimen/dimen_16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/roboto_medium"
                            android:text="times"
                            android:textColor="@color/edittext_color"
                            android:textSize="@dimen/dimen_14sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:background="@color/white"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/limitedusagelayout">

                        <LinearLayout
                            android:id="@+id/redeemlayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dimen_4dp">

                                <ImageView
                                    android:layout_width="@dimen/dimen_20dp"
                                    android:layout_height="@dimen/dimen_20dp"
                                    android:layout_gravity="center"
                                    android:padding="@dimen/dimen_2dp"
                                    android:src="@drawable/gifticon"
                                    app:tint="@color/green" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:fontFamily="@font/roboto_medium"
                                    android:text="Ready to Redeem"
                                    android:layout_marginLeft="@dimen/dimen_6dp"
                                    android:textColor="@color/green"
                                    android:textSize="@dimen/dimen_12sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/roboto_medium"
                                android:layout_marginLeft="@dimen/dimen_4dp"
                                android:layout_marginTop="@dimen/dimen_4dp"
                                android:text="Redeem this coupon before it expires"
                                android:textColor="@color/green"
                                android:textSize="@dimen/dimen_12sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/expiringlayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dimen_4dp">

                                <ImageView
                                    android:layout_width="@dimen/dimen_20dp"
                                    android:layout_height="@dimen/dimen_20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/warning" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:fontFamily="@font/roboto_medium"
                                    android:text="Expiring Soon"
                                    android:textColor="@color/red"
                                    android:textSize="@dimen/dimen_12sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/roboto_medium"
                                android:layout_marginLeft="@dimen/dimen_4dp"
                                android:text="Complete your target to redeem this service"
                                android:textColor="@color/red"
                                android:textSize="@dimen/dimen_12sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/timealertlayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dimen_4dp">

                                <ImageView
                                    android:layout_width="@dimen/dimen_20dp"
                                    android:layout_height="@dimen/dimen_20dp"
                                    android:layout_gravity="center"
                                    android:padding="@dimen/dimen_2dp"
                                    android:src="@drawable/hoursglass" />

                                <TextView
                                    android:id="@+id/expriedate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:fontFamily="@font/roboto_bold"
                                    android:text="Expires in 15h 10m 30s"
                                    android:layout_marginLeft="@dimen/dimen_6dp"
                                    android:textColor="@color/red"
                                    android:textSize="@dimen/dimen_12sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>


                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/showingprogresstarget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dimen_6dp"
                app:cardCornerRadius="@dimen/dimen_8dp"
                app:cardUseCompatPadding="true"
                app:layout_constraintTop_toBottomOf="@+id/validitycard">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="@dimen/dimen_10dp">

                    <LinearLayout
                        android:id="@+id/amountlayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dimen_10dp"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentLeft="true"
                                android:fontFamily="@font/roboto_bold"
                                android:text="Promo Target"
                                android:textColor="@color/edittext_color"
                                android:textSize="@dimen/dimen_14sp"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/targetamount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentLeft="true"
                                android:layout_marginLeft="@dimen/dimen_6dp"
                                android:fontFamily="@font/roboto_bold"
                                android:text="(₹ ______)"
                                android:textColor="@color/text_color"
                                android:textSize="@dimen/dimen_14sp"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="right"
                            android:visibility="gone">


                            <TextView
                                android:id="@+id/earnedamount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentLeft="true"
                                android:fontFamily="@font/roboto_bold"
                                android:text="₹ 500.00"
                                android:textColor="@color/green"
                                android:textSize="@dimen/dimen_14sp"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentLeft="true"
                                android:layout_marginLeft="@dimen/dimen_6dp"
                                android:fontFamily="@font/roboto_bold"
                                android:text="Earned"
                                android:textColor="@color/green"
                                android:textSize="@dimen/dimen_14sp"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                        </LinearLayout>

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dimen_14dp"
                        android:layout_marginHorizontal="@dimen/dimen_6dp"
                        android:layout_marginTop="@dimen/dimen_6dp"
                        android:max="100"
                        android:progressDrawable="@drawable/progress_drawable"
                        app:layout_constraintTop_toBottomOf="@+id/amountlayout" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dimen_10dp"
                        android:orientation="vertical"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/progressBar">


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dimen_6dp">


                            <TextView
                                android:id="@+id/achievedamount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentLeft="true"
                                android:fontFamily="@font/roboto_bold"
                                android:text="₹ _____"
                                android:textColor="@color/blue"
                                android:textSize="@dimen/dimen_14sp"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentLeft="true"
                                android:layout_marginLeft="@dimen/dimen_6dp"
                                android:fontFamily="@font/roboto_bold"
                                android:text="of"
                                android:textColor="@color/text_color"
                                android:textSize="@dimen/dimen_14sp"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/maxamount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentLeft="true"
                                android:layout_marginLeft="@dimen/dimen_6dp"
                                android:fontFamily="@font/roboto_bold"
                                android:text="₹ _____"
                                android:textColor="@color/text_color"
                                android:textSize="@dimen/dimen_14sp"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentLeft="true"
                                android:layout_marginLeft="@dimen/dimen_6dp"
                                android:fontFamily="@font/roboto_bold"
                                android:text="achieved"
                                android:textColor="@color/text_color"
                                android:textSize="@dimen/dimen_14sp"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dimen_2dp"
                            android:layout_below="@+id/offeramount"
                            android:layout_marginTop="@dimen/dimen_6dp"
                            android:background="@color/moregreylight" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="@dimen/dimen_6dp">

                            <ImageView
                                android:layout_width="@dimen/dimen_30dp"
                                android:layout_height="@dimen/dimen_30dp"
                                android:layout_gravity="center"
                                android:layout_marginLeft="-3dp"
                                android:padding="@dimen/dimen_4dp"
                                android:src="@drawable/infopromo" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentLeft="true"
                                android:layout_gravity="center"
                                android:fontFamily="@font/roboto_bold"
                                android:text="Cashback credited after target completion"
                                android:textColor="@color/text_color"
                                android:textSize="@dimen/dimen_14sp"
                                app:layout_constraintLeft_toLeftOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                        </LinearLayout>


                    </LinearLayout>


                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/completetarget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dimen_6dp"
                app:cardCornerRadius="@dimen/dimen_8dp"
                app:cardUseCompatPadding="true"
                app:layout_constraintTop_toBottomOf="@+id/showingprogresstarget">


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="@dimen/dimen_10dp">

                    <LinearLayout
                        android:id="@+id/targetcompletelayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/dimen_2dp"
                        android:layout_marginTop="@dimen/dimen_2dp"
                        android:background="@drawable/completetargetback"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/dimen_4dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight=".5"
                                android:gravity="start">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    app:cardBackgroundColor="@color/light_green"
                                    app:cardCornerRadius="@dimen/dimen_6dp"
                                    app:cardUseCompatPadding="true">

                                    <ImageView
                                        android:layout_width="@dimen/dimen_40dp"
                                        android:layout_height="@dimen/dimen_40dp"
                                        android:padding="@dimen/dimen_8dp"
                                        android:src="@drawable/checkiconn"
                                        app:tint="@color/green" />

                                </androidx.cardview.widget.CardView>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/roboto_medium"
                                    android:text="Target Completed"
                                    android:textColor="@color/text_color"
                                    android:textSize="@dimen/dimen_16sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/roboto_regular"
                                    android:text="Cashback Earned"
                                    android:textColor="@color/text_color"
                                    android:textSize="@dimen/dimen_14sp" />

                                <TextView
                                    android:id="@+id/earnedamountforwithdraw"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/roboto_bold"
                                    android:text="₹ _____"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/dimen_18sp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/roboto_regular"
                                    android:gravity="right"
                                    android:text="Promo Code"
                                    android:textColor="@color/text_color"
                                    android:textSize="@dimen/dimen_14sp" />

                                <TextView
                                    android:id="@+id/promocodeforachieved"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/roboto_bold"
                                    android:gravity="right"
                                    android:text="WALLETTOP"
                                    android:textColor="@color/blue"
                                    android:textSize="@dimen/dimen_16sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/redeemcard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        app:cardBackgroundColor="@color/blue"
                        app:cardCornerRadius="@dimen/dimen_6dp"
                        app:cardUseCompatPadding="true"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/targetcompletelayout">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/roboto_regular"
                                android:gravity="center"
                                android:paddingHorizontal="@dimen/dimen_16dp"
                                android:paddingVertical="@dimen/dimen_4dp"
                                android:text="Redeem"
                                android:textColor="@color/white"
                                android:textSize="@dimen/dimen_14sp"
                                android:textStyle="bold" />

                        </LinearLayout>


                    </androidx.cardview.widget.CardView>


                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>





</androidx.constraintlayout.widget.ConstraintLayout>