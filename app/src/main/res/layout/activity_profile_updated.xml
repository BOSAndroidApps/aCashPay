<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F3F7"
    tools:context=".ui.view.Dashboard.activity.ProfileUpdated">

    <!-- Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/blue">

        <ImageView
            android:id="@+id/back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_120dp"
                android:translationY="25dp"
                android:gravity="center"
                android:elevation="@dimen/dimen_20dp">

                <!-- Profile Image -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/profilecard"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    app:cardCornerRadius="55dp">

                    <ImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_d_profile" />

                </androidx.cardview.widget.CardView>

                <ImageView
                    android:id="@+id/cameraicon"
                    android:layout_width="@dimen/dimen_50dp"
                    android:layout_height="@dimen/dimen_50dp"
                    android:src="@drawable/cameraicon"
                    android:elevation="@dimen/dimen_2dp"
                    android:layout_marginRight="-20dp"
                    android:padding="@dimen/dimen_4dp"
                    android:layout_alignRight="@id/profilecard"
                    android:layout_alignBottom="@id/profilecard"/>

            </RelativeLayout>

            <!-- Main Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                android:layout_marginTop="-30dp"
                app:cardUseCompatPadding="true"
                android:paddingTop="45dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="14dp"
                    android:layout_marginTop="@dimen/dimen_50dp">

                    <TextView
                        android:id="@+id/tvFullName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Demo"
                        android:textSize="20sp"
                        android:textColor="#222222"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvMobileNo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8929898989"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:layout_marginTop="3dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="14dp"
                        android:background="#E0E0E0"/>

                    <include
                        android:id="@+id/profilerowlayout"
                        layout="@layout/profile_row"
                        />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/updateBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="@dimen/dimen_8dp"
                android:backgroundTint="#0D47A1"
                android:text="UPDATE"
                android:textColor="#FFFFFF"
                android:alpha=".4"
                app:layout_constraintBottom_toBottomOf="parent" />


        </LinearLayout>

    </ScrollView>




</LinearLayout>
